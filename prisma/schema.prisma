generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  admin
  maintainer
  viewer
}

enum AgentStatus {
  connected
  idle
  offline
}

enum SyncJobStatus {
  pending
  running
  success
  failed
}

enum AlertLevel {
  info
  warning
  critical
}

enum AlertStatus {
  open
  resolved
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  name         String           
  role         UserRole          @default(viewer)
  passwordHash String           
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  sessions     Session[]
  memberships  WorkspaceMember[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique @db.VarChar(512)
  userId    String  
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workspace {
  id              String             @id @default(cuid())
  slug            String             @unique
  name            String            
  description     String?           
  rootPath        String?           
  status          String             @default("active")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  members         WorkspaceMember[]
  agents          WorkspaceAgent[]
  syncJobs        SyncJob[]
  registryItems   RegistryItem[]
  registryLinks   RegistryRelation[]
  runStates       RunState[]
  runEvents       RunEvent[]
  runExecutions   RunRoleExecution[]
  changeDocuments ChangeDocument[]
  omxSessions     OmxSession[]
  omxTurns        OmxTurn[]
  alerts          Alert[]
  rawEvents       RawIngestEvent[]
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String   
  userId      String   
  role        UserRole
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model WorkspaceAgent {
  id           String      @id @default(cuid())
  workspaceId  String     
  agentId      String     
  label        String?    
  status       AgentStatus @default(offline)
  capabilities Json?
  lastSeenAt   DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  workspace    Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, agentId])
}

model SyncJob {
  id          String        @id @default(cuid())
  workspaceId String       
  mode        String       
  status      SyncJobStatus @default(pending)
  summary     Json?
  error       String?      
  startedAt   DateTime      @default(now())
  finishedAt  DateTime?
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model RegistryItem {
  id          String    @id @default(cuid())
  workspaceId String   
  category    String   
  slug        String   
  name        String   
  label       String?  
  status      String?  
  version     Int       @default(1)
  sourcePath  String   
  payload     Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, category, slug])
}

model RegistryRelation {
  id             String    @id @default(cuid())
  workspaceId    String   
  sourceCategory String   
  sourceSlug     String   
  relationType   String   
  targetSlug     String   
  createdAt      DateTime  @default(now())
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, sourceCategory, sourceSlug, relationType, targetSlug])
}

model RunState {
  id             String    @id @default(cuid())
  workspaceId    String   
  runKey         String   
  status         String?  
  lastEventType  String   
  lastOccurredAt DateTime
  turnCount      Int       @default(0)
  payload        Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, runKey])
}

model RunEvent {
  id          String    @id @default(cuid())
  workspaceId String   
  runKey      String   
  eventType   String   
  occurredAt  DateTime
  payload     Json
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model RunRoleExecution {
  id          String    @id @default(cuid())
  workspaceId String   
  runKey      String   
  roleSlug    String   
  status      String   
  startedAt   DateTime?
  endedAt     DateTime?
  payload     Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model ChangeDocument {
  id          String    @id @default(cuid())
  workspaceId String   
  changeKey   String   
  docType     String   
  title       String?  
  sourcePath  String   
  contentHash String?  
  status      String?  
  archivedAt  DateTime?
  payload     Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, changeKey, docType, sourcePath])
}

model OmxSession {
  id              String    @id @default(cuid())
  workspaceId     String   
  sessionKey      String   
  nativeSessionId String?  
  event           String   
  pid             Int?
  timestamp       DateTime
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, sessionKey])
}

model OmxTurn {
  id            String    @id @default(cuid())
  workspaceId   String   
  sessionKey    String   
  turnKey       String   
  type          String   
  timestamp     DateTime
  inputPreview  String?  
  outputPreview String?  
  createdAt     DateTime  @default(now())
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, turnKey])
}

model Alert {
  id          String      @id @default(cuid())
  workspaceId String     
  level       AlertLevel
  title       String     
  message     String     
  status      AlertStatus @default(open)
  payload     Json?
  createdAt   DateTime    @default(now())
  resolvedAt  DateTime?
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model RawIngestEvent {
  id             String    @id @default(cuid())
  workspaceId    String   
  eventId        String   
  idempotencyKey String    @unique
  sourceType     String   
  eventType      String   
  occurredAt     DateTime
  sourcePath     String   
  contentHash    String   
  payload        Json
  createdAt      DateTime  @default(now())
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, eventId])
}

enum ControlOutboxStatus {
  pending
  delivered
  applied
  conflict
  rejected
  expired
}

model ControlOutbox {
  id          String              @id @default(cuid())
  workspaceId String
  runKey      String
  command     String
  payload     Json
  signature   String              @db.VarChar(128)
  status      ControlOutboxStatus @default(pending)
  actorId     String?
  reason      String?             @db.Text
  appliedSnapshot Json?
  createdAt   DateTime            @default(now())
  deliveredAt DateTime?
  appliedAt   DateTime?
  expiresAt   DateTime?

  @@index([workspaceId, status, createdAt])
  @@index([runKey, status])
}
