generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  admin
  maintainer
  viewer
}

enum AgentStatus {
  connected
  idle
  offline
}

enum SyncJobStatus {
  pending
  running
  success
  failed
}

enum AlertLevel {
  info
  warning
  critical
}

enum AlertStatus {
  open
  resolved
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  name         String           
  role         UserRole          @default(viewer)
  passwordHash String           
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  sessions     Session[]
  memberships  WorkspaceMember[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique @db.VarChar(512)
  userId    String  
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workspace {
  id              String             @id @default(cuid())
  slug            String             @unique
  name            String            
  description     String?           
  rootPath        String?           
  status          String             @default("active")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  members         WorkspaceMember[]
  agents          WorkspaceAgent[]
  syncJobs        SyncJob[]
  registryItems   RegistryItem[]
  registryLinks   RegistryRelation[]
  runStates       RunState[]
  runEvents       RunEvent[]
  runExecutions   RunRoleExecution[]
  changeDocuments ChangeDocument[]
  omxSessions     OmxSession[]
  omxTurns        OmxTurn[]
  alerts          Alert[]
  rawEvents       RawIngestEvent[]
  specAssets      SpecAsset[]
  gateApprovals   GateApproval[]
  timelineEvents  TimelineEvent[]
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String   
  userId      String   
  role        UserRole
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model WorkspaceAgent {
  id           String      @id @default(cuid())
  workspaceId  String     
  agentId      String     
  label        String?    
  status       AgentStatus @default(offline)
  capabilities Json?
  lastSeenAt   DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  workspace    Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, agentId])
}

model SyncJob {
  id          String        @id @default(cuid())
  workspaceId String       
  mode        String       
  status      SyncJobStatus @default(pending)
  summary     Json?
  error       String?      
  startedAt   DateTime      @default(now())
  finishedAt  DateTime?
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model RegistryItem {
  id          String    @id @default(cuid())
  workspaceId String   
  category    String   
  slug        String   
  name        String   
  label       String?  
  status      String?  
  version     Int       @default(1)
  sourcePath  String   
  payload     Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, category, slug])
}

model RegistryRelation {
  id             String    @id @default(cuid())
  workspaceId    String   
  sourceCategory String   
  sourceSlug     String   
  relationType   String   
  targetSlug     String   
  createdAt      DateTime  @default(now())
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, sourceCategory, sourceSlug, relationType, targetSlug])
}

model RunState {
  id             String    @id @default(cuid())
  workspaceId    String   
  runKey         String   
  status         String?  
  lastEventType  String   
  lastOccurredAt DateTime
  turnCount      Int       @default(0)
  payload        Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, runKey])
}

model RunEvent {
  id          String    @id @default(cuid())
  workspaceId String   
  runKey      String   
  eventType   String   
  occurredAt  DateTime
  payload     Json
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model RunRoleExecution {
  id          String    @id @default(cuid())
  workspaceId String   
  runKey      String   
  roleSlug    String   
  status      String   
  startedAt   DateTime?
  endedAt     DateTime?
  payload     Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model ChangeDocument {
  id          String    @id @default(cuid())
  workspaceId String   
  changeKey   String   
  docType     String   
  title       String?  
  sourcePath  String   
  contentHash String?  
  status      String?  
  archivedAt  DateTime?
  payload     Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, changeKey, docType, sourcePath])
}

model SpecAsset {
  id          String    @id @default(cuid())
  workspaceId String
  runId       String?
  changeId    String?
  sourceKind  String
  sourcePath  String
  assetType   String
  status      String
  title       String?
  roleCode    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, sourceKind, sourcePath])
  @@index([workspaceId, runId, sourceKind])
  @@index([workspaceId, changeId, sourceKind])
}

model GateApproval {
  id                 String    @id @default(cuid())
  workspaceId        String
  runId              String
  nodeId             String    @default("")
  roleCode           String?
  gateType           String
  status             String
  mode               String
  reason             String?   @db.Text
  requiredAssetsJson Json?
  reviewer           String?
  comment            String?   @db.Text
  resolution         String?
  approvedAt         DateTime?
  rejectedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, runId, nodeId, gateType])
  @@index([workspaceId, runId, status])
}

model TimelineEvent {
  id          String    @id @default(cuid())
  workspaceId String
  runId       String?
  nodeId      String?
  type        String
  title       String
  payload     Json?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, runId, createdAt])
  @@index([workspaceId, type, createdAt])
}

model OmxSession {
  id              String    @id @default(cuid())
  workspaceId     String   
  sessionKey      String   
  nativeSessionId String?  
  event           String   
  pid             Int?
  timestamp       DateTime
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, sessionKey])
}

model OmxTurn {
  id            String    @id @default(cuid())
  workspaceId   String   
  sessionKey    String   
  turnKey       String   
  type          String   
  timestamp     DateTime
  inputPreview  String?   @db.Text
  outputPreview String?   @db.Text
  createdAt     DateTime  @default(now())
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, turnKey])
}

model Alert {
  id          String      @id @default(cuid())
  workspaceId String     
  level       AlertLevel
  title       String     
  message     String     
  status      AlertStatus @default(open)
  payload     Json?
  createdAt   DateTime    @default(now())
  resolvedAt  DateTime?
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model RawIngestEvent {
  id             String    @id @default(cuid())
  workspaceId    String   
  eventId        String   
  idempotencyKey String    @unique
  sourceType     String   
  eventType      String   
  occurredAt     DateTime
  sourcePath     String   
  contentHash    String   
  payload        Json
  createdAt      DateTime  @default(now())
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, eventId])
}

enum ControlOutboxStatus {
  pending
  delivered
  applied
  conflict
  rejected
  expired
}

model ControlOutbox {
  id          String              @id @default(cuid())
  workspaceId String
  runKey      String
  command     String
  payload     Json
  signature   String              @db.VarChar(128)
  status      ControlOutboxStatus @default(pending)
  actorId     String?
  reason      String?             @db.Text
  appliedSnapshot Json?
  createdAt   DateTime            @default(now())
  deliveredAt DateTime?
  appliedAt   DateTime?
  expiresAt   DateTime?

  @@index([workspaceId, status, createdAt])
  @@index([runKey, status])
}

model Installation {
  id             String                @id @default(cuid())
  installationId String                @unique
  hostname       String?
  username       String?
  platform       String?
  arch           String?
  osRelease      String?
  nodeVersion    String?
  firstSeenAt    DateTime              @default(now())
  lastSeenAt     DateTime              @default(now())
  lastCommand    String?
  lastCliVersion String?
  totalEvents    Int                   @default(0)
  events         InstallationEvent[]
  projects       InstallationProject[]

  @@index([lastSeenAt])
}

model InstallationEvent {
  id             String       @id @default(cuid())
  installationId String
  command        String
  status         String
  cliVersion     String?
  profile        String?
  ides           Json?
  level          String?
  projectHash    String?
  projectName    String?
  durationMs     Int?
  errorMessage   String?      @db.Text
  occurredAt     DateTime     @default(now())
  installation   Installation @relation(fields: [installationId], references: [installationId], onDelete: Cascade)

  @@index([installationId, occurredAt])
  @@index([command, occurredAt])
  @@index([occurredAt])
}

model InstallationProject {
  id             String       @id @default(cuid())
  installationId String
  projectHash    String
  projectName    String?
  profile        String?
  firstSeenAt    DateTime     @default(now())
  lastSeenAt     DateTime     @default(now())
  eventCount     Int          @default(0)
  installation   Installation @relation(fields: [installationId], references: [installationId], onDelete: Cascade)

  @@unique([installationId, projectHash])
  @@index([firstSeenAt])
}

model VisualProject {
  id          String   @id @default(cuid())
  projectId   String   @unique
  workspaceId String?
  projectHash String?
  name        String?
  type        String
  techProfile Json
  manifest    Json
  packages    Json
  lastRunId   String?
  riskLevel   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
  @@index([lastRunId])
}

model VisualRun {
  id                  String    @id @default(cuid())
  runId               String    @unique
  projectId           String
  workspaceId          String?
  requirementSummary  String?   @db.Text
  state               String
  stage               String
  executor            String?
  manifest            Json
  branch              Json
  worktree            Json
  contextSummary      Json
  verificationSummary Json
  startedAt           DateTime?
  completedAt         DateTime?
  durationMs          Int?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([projectId])
  @@index([workspaceId])
  @@index([state])
  @@index([stage])
}

model VisualRuntimeEvent {
  id        String   @id @default(cuid())
  eventId   String   @unique
  runId     String
  projectId String
  type      String
  stage     String?
  state     String?
  level     String
  payload   Json
  createdAt DateTime @default(now())

  @@index([runId])
  @@index([projectId])
  @@index([type])
  @@index([level])
}

model VisualHistoryItem {
  id                  String   @id @default(cuid())
  historyId           String   @unique
  runId               String?
  projectId           String
  title               String
  summary             String   @db.Text
  changedFiles        Json
  assetsUsed          Json
  verificationSummary Json
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([runId])
  @@index([projectId])
}

model VisualIncident {
  id             String   @id @default(cuid())
  incidentId     String   @unique
  runId          String
  projectId      String
  type           String
  level          String
  stage          String?
  message        String   @db.Text
  suggestion     String?  @db.Text
  diagnoseResult Json
  recoveryAction Json
  status         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([runId])
  @@index([projectId])
  @@index([level])
  @@index([status])
}
